#################################
# WealthOS Local Environment
#################################
# Copy this file to .env.local for local development.
# Never commit .env.local or production secrets.

#################################
# Database
#################################
# Required for local database access and Prisma migrations.
# Update the username, password, host, port, and database name for your machine.
DATABASE_URL="postgresql://wealthos:wealthos@localhost:5432/wealthos?schema=public"

#################################
# Authentication
#################################
# Required for Auth.js at runtime.
# Generate a local secret with:
#
#   npx auth secret
#
# and place the generated AUTH_SECRET in .env.local.
AUTH_SECRET=

# Auth.js canonical URL. Safe localhost defaults are supported in development.
AUTH_URL="http://localhost:3000"

# Compatibility fallback for older NextAuth/Auth.js setups.
# If both AUTH_URL and NEXTAUTH_URL are set, WealthOS uses AUTH_URL.
NEXTAUTH_URL="http://localhost:3000"

# Safe for local development behind localhost.
# Production deployments should configure trusted hosts explicitly.
AUTH_TRUST_HOST="true"

# Session lifetime controls, in seconds.
AUTH_SESSION_MAX_AGE_SECONDS="2592000"
AUTH_SESSION_UPDATE_AGE_SECONDS="86400"

# Development-only credential sign-in.
# Ignored in production, where OAuth or email sign-in must be configured.
WEALTHOS_ENABLE_DEV_CREDENTIALS="true"

#################################
# Google OAuth
#################################
# Optional in development.
# Required in production unless secure email authentication is configured.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Compatibility aliases. Prefer AUTH_GOOGLE_ID and AUTH_GOOGLE_SECRET.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

#################################
# Email Authentication
#################################
# Optional in development.
# Required in production unless Google OAuth is configured.
# Example server format:
# smtp://username:password@smtp.example.com:587
AUTH_EMAIL_SERVER=
AUTH_EMAIL_FROM=

#################################
# AI Providers
#################################
# Optional. WealthOS uses deterministic advisory insights when no AI provider is configured.
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

#################################
# News Providers
#################################
# Optional. Enables symbol-linked news through the configured news provider.
NEWS_API_KEY=

#################################
# Pricing Providers
#################################
# No pricing API keys are required by the current implementation.
# Yahoo Finance, CoinGecko, and AMFI use public endpoints.
# Gold/manual prices can be supplied through asset metadata.

#################################
# Background Jobs
#################################
# Optional locally. Configure when running scheduled jobs through Trigger.dev.
TRIGGER_SECRET_KEY=

#################################
# Object Storage
#################################
# Optional. Reserved for Cloudflare R2/S3-compatible storage features.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
